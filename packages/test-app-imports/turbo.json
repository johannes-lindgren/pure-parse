{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "test": {
      "dependsOn": ["test:build", "test:types"]
    },
    "test:build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test:types": {
      "dependsOn": ["^build"]
    }
  }
}
